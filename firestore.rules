rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * DLX AI STUDIOS SECURITY RULES
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /settings/{settingId} {
        allow read, write: if isOwner(userId);
      }

      match /smart_folio_reports/{reportId} {
        allow read, write: if isOwner(userId);
      }

      // Simplified rules for AI Conversations to prevent "Missing permissions" errors
      // while we are rapidly prototyping the chat interface.
      match /ai_conversations/{conversationId} {
        allow read, write: if isOwner(userId);

        match /messages/{messageId} {
          allow read, write: if isOwner(userId);
        }
      }
    }

    // Public read-only collections
    match /ai_studios/{studioId} {
      allow read: if true;
      allow write: if false; 
    }

    match /ai_agent_personas/{agentPersonaId} {
      allow read: if true;
      allow write: if false;
    }

    match /news_articles/{articleId} {
      allow read: if true;
      allow write: if false;
    }

    match /lab_projects/{projectId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
